{
  "name": "state-jet",
  "version": "2.4.13",
  "description": "Ultra-lightweight global state management for React",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/venkateshsundaram/state-jet.git"
  },
  "homepage": "https://statejet.org",
  "keywords": [
    "react",
    "state",
    "state-management",
    "global-state",
    "global-state-management",
    "state-jet",
    "statejet",
    "state-jet-react",
    "react-state-jet",
    "react-hooks",
    "store",
    "hooks",
    "javascript",
    "typescript",
    "global",
    "react-state-management",
    "global-state-hooks",
    "state-hooks",
    "use-store",
    "client-state",
    "react-utility",
    "hooks-utility",
    "redux-alternative",
    "context-alternative"
  ],
  "author": "venkateshsundaram",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/venkateshsundaram/state-jet/issues"
  },
  "scripts": {
    "build": "rimraf dist && rollup -c",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist",
    "publish:npm": "npm publish --access public",
    "lint": "eslint src --max-warnings 0",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "release": "standard-version",
    "postrelease": "git push --follow-tags",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@rollup/plugin-commonjs": "^28.0.2",
    "@rollup/plugin-node-resolve": "^15.0.2",
    "@rollup/plugin-terser": "^1.0.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "immer": "^10.1.1",
    "jsdom": "^26.0.0",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "rimraf": "^6.1.3",
    "rollup": "^3.29.4",
    "rollup-plugin-dts": "^5.3.0",
    "rollup-plugin-esbuild": "^5.0.0",
    "standard-version": "^9.5.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "@types/react": ">=18.0.0",
    "immer": ">=9.0.6",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    },
    "immer": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "overrides": {
    "minimatch": "^10.0.0",
    "yargs-parser": "^21.0.0"
  },
  "type": "module"
}
